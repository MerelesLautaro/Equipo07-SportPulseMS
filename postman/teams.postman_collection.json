                  "});",
                  "pm.test(\"Team is national\", () => {",
                  "    const team = pm.response.json();",
                  "    pm.expect(team.national).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
