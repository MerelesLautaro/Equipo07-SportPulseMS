    {
      "name": "2. GET /api/teams/{teamId} - Detalle de equipo por ID",
      "item": [
        {
          "name": "Happy - Detalle de equipo válido",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/teams/{{team_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "teams", "{{team_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response is an object\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "});",
                  "pm.test(\"Response has required team fields\", () => {",
                  "    const team = pm.response.json();",
                  "    pm.expect(team).to.have.property('id');",
                  "    pm.expect(team).to.have.property('name');",
                  "    pm.expect(team).to.have.property('country');",
                  "    pm.expect(team).to.have.property('logo');",
                  "    pm.expect(team).to.have.property('founded');",
                  "    pm.expect(team).to.have.property('national');",
                  "    pm.expect(team).to.have.property('stadium');",
                  "});",
                  "pm.test(\"Stadium has complete details\", () => {",
                  "    const team = pm.response.json();",
                  "    pm.expect(team.stadium).to.have.property('name');",
                  "    pm.expect(team.stadium).to.have.property('city');",
                  "    pm.expect(team.stadium).to.have.property('capacity');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Happy - Equipo nacional (national: true)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
