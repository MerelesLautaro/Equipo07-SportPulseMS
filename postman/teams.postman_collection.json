  "item": [
    {
      "name": "1. GET /api/teams - Listar equipos por liga y temporada",
      "item": [
        {
          "name": "Happy - Con league y season (parámetros requeridos)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/teams?league={{league_id}}&season={{season}}",
              "host": ["{{base_url}}"],
              "path": ["api", "teams"],
              "query": [
                { "key": "league", "value": "{{league_id}}" },
                { "key": "season", "value": "{{season}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response is an array\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "pm.test(\"Response has required team structure\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        const team = jsonData[0];",
                  "        pm.expect(team).to.have.property('id');",
                  "        pm.expect(team).to.have.property('name');",
                  "        pm.expect(team).to.have.property('country');",
                  "        pm.expect(team).to.have.property('logo');",
                  "        pm.expect(team).to.have.property('founded');",
                  "        pm.expect(team).to.have.property('stadium');",
                  "        pm.expect(team.stadium).to.have.property('name');",
                  "        pm.expect(team.stadium).to.have.property('city');",
                  "        pm.expect(team.stadium).to.have.property('capacity');",
                  "    }",
                  "});",
                  "pm.test(\"Logo URL is valid format\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        pm.expect(jsonData[0].logo).to.include('api-sports.io');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
