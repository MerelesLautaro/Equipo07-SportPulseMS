          ]
        }
      ]
    },
    {
      "name": "GET League by ID - Happy Paths",
      "item": [
        {
          "name": "Detalle de liga existente (200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leagues/140",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"La respuesta contiene id\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.id).to.eql(140);",
                  "});",
                  "pm.test(\"La respuesta contiene name\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "});",
                  "pm.test(\"La respuesta contiene type\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('type');",
                  "});",
                  "pm.test(\"La respuesta contiene country\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('country');",
                  "});",
                  "pm.test(\"La respuesta contiene seasons (array)\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('seasons');",
                  "    pm.expect(jsonData.seasons).to.be.an('array');",
                  "});",
                  "pm.test(\"La respuesta contiene currentSeason (object)\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('currentSeason');",
                  "    pm.expect(jsonData.currentSeason).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "GET League by ID - Bad Paths",
      "item": [
