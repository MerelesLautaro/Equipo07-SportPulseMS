{
  "info": {
    "name": "SportPulse - Leagues Service",
    "description": "Colección de tests para ms-leagues - League Controller",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "GET Leagues - Happy Paths",
      "item": [
        {
          "name": "Listar todas las ligas (sin parametros)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leagues",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"La respuesta es un array\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "pm.test(\"Cada liga tiene campos requeridos\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        const league = jsonData[0];",
                  "        pm.expect(league).to.have.property('id');",
                  "        pm.expect(league).to.have.property('name');",
                  "        pm.expect(league).to.have.property('type');",
                  "        pm.expect(league).to.have.property('country');",
                  "        pm.expect(league).to.have.property('currentSeason');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar ligas filtradas por country",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/leagues?country=Spain",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leagues"],
              "query": [
                {
                  "key": "country",
                  "value": "Spain"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"La respuesta es un array\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar ligas filtradas por season",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/leagues?season=2024",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leagues"],
              "query": [
                {
                  "key": "season",
                  "value": "2024"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar ligas con country y season",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/leagues?country=England&season=2024",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leagues"],
              "query": [
                {
                  "key": "country",
                  "value": "England"
                },
                {
                  "key": "season",
                  "value": "2024"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "GET Leagues - Bad Paths",
      "item": [
