              {
                "key": "Authorization",
                "value": "Bearer invalid_token_123"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 401\", () => {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Liga no encontrada (404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leagues/999999",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 404\", () => {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test(\"La respuesta contiene error\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "    pm.expect(jsonData.error).to.eql('LEAGUE_NOT_FOUND');",
                  "});",
                  "pm.test(\"La respuesta contiene message\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "});",
                  "pm.test(\"La respuesta contiene timestamp\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}

