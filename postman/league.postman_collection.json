                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Token vacio (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/leagues",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer "
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 401\", () => {",
