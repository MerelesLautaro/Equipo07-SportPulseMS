                  "pm.test(\"Response is an array\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "pm.test(\"Events have required structure\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        const event = jsonData[0];",
                  "        pm.expect(event).to.have.property('elapsed');",
                  "        pm.expect(event).to.have.property('type');",
                  "        pm.expect(event).to.have.property('detail');",
                  "        pm.expect(event).to.have.property('team');",
