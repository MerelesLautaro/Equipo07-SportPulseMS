      "name": "1. GET /api/fixtures - Listar fixtures",
      "item": [
        {
          "name": "Happy - Sin filtros (todos los fixtures)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/fixtures",
              "host": ["{{base_url}}"],
              "path": ["api", "fixtures"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response is an array\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "pm.test(\"Response has required structure\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        const fixture = jsonData[0];",
                  "        pm.expect(fixture).to.have.property('id');",
                  "        pm.expect(fixture).to.have.property('date');",
                  "        pm.expect(fixture).to.have.property('status');",
                  "        pm.expect(fixture).to.have.property('league');",
                  "        pm.expect(fixture).to.have.property('homeTeam');",
                  "        pm.expect(fixture).to.have.property('awayTeam');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
