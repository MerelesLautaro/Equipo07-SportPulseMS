{
  "info": {
    "name": "SportPulse MS Standings API",
    "description": "Colección de tests para los endpoints de clasificación del Microservicio Standings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "leagueId",
      "value": "39",
      "type": "number"
    },
    {
      "key": "seasonYear",
      "value": "2024",
      "type": "number"
    },
    {
      "key": "teamId",
      "value": "40",
      "type": "number"
    }
  ],
  "item": [
    {
      "name": "GET /api/standings - Happy Path",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/standings?league={{leagueId}}&season={{seasonYear}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "standings"],
          "query": [
            { "key": "league", "value": "{{leagueId}}" },
            { "key": "season", "value": "{{seasonYear}}" }
          ]
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has league object\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('league');",
              "    pm.expect(jsonData.league).to.have.property('id');",
              "    pm.expect(jsonData.league).to.have.property('name');",
              "    pm.expect(jsonData.league).to.have.property('country');",
              "    pm.expect(jsonData.league).to.have.property('season');",
              "});",
              "",
              "pm.test(\"Response has standings array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('standings');",
              "    pm.expect(jsonData.standings).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Standings entries have required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.standings.length > 0) {",
              "        const entry = jsonData.standings[0];",
              "        pm.expect(entry).to.have.property('rank');",
              "        pm.expect(entry).to.have.property('team');",
              "        pm.expect(entry.team).to.have.property('id');",
              "        pm.expect(entry.team).to.have.property('name');",
              "        pm.expect(entry).to.have.property('points');",
              "        pm.expect(entry).to.have.property('played');",
              "        pm.expect(entry).to.have.property('won');",
              "        pm.expect(entry).to.have.property('drawn');",
              "        pm.expect(entry).to.have.property('lost');",
              "    }",
              "});",
              "",
              "pm.test(\"Response time is acceptable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ]
          }
        }
      ]
    },
