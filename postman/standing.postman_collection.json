    {
      "name": "GET /api/standings/team/{teamId} - Happy Path",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/standings/team/{{teamId}}?league={{leagueId}}&season={{seasonYear}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "standings", "team", "{{teamId}}"],
          "query": [
            { "key": "league", "value": "{{leagueId}}" },
            { "key": "season", "value": "{{seasonYear}}" }
          ]
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has team object\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('team');",
              "    pm.expect(jsonData.team).to.have.property('id');",
              "    pm.expect(jsonData.team).to.have.property('name');",
              "});",
              "",
              "pm.test(\"Response has league info\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('league');",
              "    pm.expect(jsonData.league).to.have.property('id');",
              "    pm.expect(jsonData.league).to.have.property('name');",
              "});",
              "",
              "pm.test(\"Response has standing fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('season');",
              "    pm.expect(jsonData).to.have.property('rank');",
              "    pm.expect(jsonData).to.have.property('points');",
              "    pm.expect(jsonData).to.have.property('played');",
              "    pm.expect(jsonData).to.have.property('form');",
              "    pm.expect(jsonData).to.have.property('description');",
              "});",
              "",
              "pm.test(\"Rank is a positive number\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.rank).to.be.a('number');",
              "    pm.expect(jsonData.rank).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Points and played are non-negative\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.points).to.be.at.least(0);",
              "    pm.expect(jsonData.played).to.be.at.least(0);",
              "});"
            ]
          }
        }
      ]
