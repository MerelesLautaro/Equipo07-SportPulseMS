    {
      "name": "POST Validate - Happy Path",
      "item": [
        {
          "name": "Validate - Token valido (200)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/validate",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Internal-Secret",
                "value": "{{internalSecret}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"La respuesta contiene valid\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('valid');",
                  "    pm.expect(jsonData.valid).to.be.true;",
                  "});",
                  "pm.test(\"La respuesta contiene userId\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('userId');",
                  "});",
                  "pm.test(\"La respuesta contiene username\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('username');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
