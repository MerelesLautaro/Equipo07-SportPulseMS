    {
      "name": "POST Login - Happy Path",
      "item": [
        {
          "name": "Login - Exito (200)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser001@example.com\",\n  \"password\": \"Secure@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"La respuesta contiene token\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "});",
                  "pm.test(\"La respuesta contiene tokenType\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('tokenType');",
                  "    pm.expect(jsonData.tokenType).to.eql('Bearer');",
                  "});",
                  "pm.test(\"La respuesta contiene expiresIn\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('expiresIn');",
                  "});",
                  "pm.test(\"Guardar token en variable\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', jsonData.token);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
