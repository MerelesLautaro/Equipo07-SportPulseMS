  "item": [
    {
      "name": "POST Register - Happy Path",
      "item": [
        {
          "name": "Register - Exito (201)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser001\",\n  \"email\": \"newuser001@example.com\",\n  \"password\": \"Secure@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 201\", () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"La respuesta contiene id\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "});",
                  "pm.test(\"La respuesta contiene username\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('username');",
                  "    pm.expect(jsonData.username).to.eql('newuser001');",
                  "});",
                  "pm.test(\"La respuesta contiene email\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('email');",
                  "    pm.expect(jsonData.email).to.eql('newuser001@example.com');",
                  "});",
                  "pm.test(\"La respuesta no contiene password\", () => {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.not.have.property('password');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
